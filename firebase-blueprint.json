{
  "entities": {
    "Article": {
      "title": "Article",
      "description": "A blog post or article written by the doctor.",
      "type": "object",
      "properties": {
        "title": {
          "type": "string",
          "description": "The title of the article."
        },
        "content": {
          "type": "string",
          "description": "The content of the article (Rich Text or Markdown)."
        },
        "format": {
          "type": "string",
          "enum": ["richtext", "markdown"],
          "description": "The format of the content."
        },
        "authorId": {
          "type": "string",
          "description": "The UID of the author."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the article was created."
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the article was last updated."
        }
      },
      "required": ["title", "content", "format", "authorId", "createdAt"]
    },
    "UserProfile": {
      "title": "UserProfile",
      "description": "Public profile information for users (admins).",
      "type": "object",
      "properties": {
        "displayName": {
          "type": "string",
          "description": "The user's display name."
        },
        "role": {
          "type": "string",
          "enum": ["admin", "user"],
          "description": "The user's role."
        }
      },
      "required": ["displayName", "role"]
    }
  },
  "firestore": {
    "/articles/{articleId}": {
      "schema": "Article",
      "description": "Collection of articles."
    },
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile documents."
    }
  }
}