rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: articles
    // Document ID: auto-generated
    // Fields:
    //   - title: string (required, 1-200 chars)
    //   - content: string (required, 1-50000 chars)
    //   - format: string (required, 'richtext' or 'markdown')
    //   - authorId: string (required, matches auth.uid)
    //   - createdAt: timestamp (required)
    //   - updatedAt: timestamp (required)
    //
    // Collection: users
    // Document ID: auth.uid
    // Fields:
    //   - displayName: string (required, 1-100 chars)
    //   - role: string (required, 'admin' or 'user')
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "taffen12@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidArticle(data) {
      return data.keys().hasAll(['title', 'content', 'format', 'authorId', 'createdAt', 'updatedAt']) &&
             data.title is string && data.title.size() >= 1 && data.title.size() <= 200 &&
             data.content is string && data.content.size() >= 1 && data.content.size() <= 50000 &&
             data.format in ['richtext', 'markdown'] &&
             data.authorId == request.auth.uid &&
             data.createdAt is timestamp &&
             data.updatedAt is timestamp;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['displayName', 'role']) &&
             data.displayName is string && data.displayName.size() >= 1 && data.displayName.size() <= 100 &&
             data.role in ['admin', 'user'];
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) && isValidUser(request.resource.data) && request.resource.data.role == 'user';
      allow update: if isOwner(userId) && isValidUser(request.resource.data) && request.resource.data.role == resource.data.role;
      allow write: if isAdmin();
    }

    match /articles/{articleId} {
      allow read: if true;
      allow create: if isAdmin() && isValidArticle(request.resource.data);
      allow update: if isAdmin() && isValidArticle(request.resource.data) && request.resource.data.authorId == resource.data.authorId;
      allow delete: if isAdmin();
    }
  }
}